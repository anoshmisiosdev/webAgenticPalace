<style>
  .panel {
    flex-direction: column;
    background-color: rgba(8, 8, 18, 0.95);
    border-radius: 22;
    padding: 18;
    gap: 10;
    width: 390;
  }

  .panel-title {
    font-size: 17;
    font-weight: bold;
    color: rgba(200, 200, 255, 1);
    align-self: center;
    letter-spacing: 5;
  }

  .status-bar {
    min-height: 24;
    padding-horizontal: 10;
    padding-vertical: 4;
    border-radius: 12;
    background-color: rgba(255, 255, 255, 0.05);
    justify-content: center;
    align-items: center;
  }

  .btn-row {
    flex-direction: row;
    gap: 8;
  }

  .btn-scout {
    flex: 1;
    padding-vertical: 12;
    padding-horizontal: 8;
    border-radius: 18;
    justify-content: center;
    align-items: center;
    background-color: rgba(124, 58, 237, 1);
  }

  .btn-gen {
    flex: 1;
    padding-vertical: 12;
    padding-horizontal: 8;
    border-radius: 18;
    justify-content: center;
    align-items: center;
    background-color: rgba(15, 118, 110, 1);
  }

  .section-label {
    font-size: 10;
    font-weight: bold;
    color: rgba(120, 120, 180, 1);
    letter-spacing: 3;
    padding-horizontal: 2;
    padding-bottom: 2;
  }

  .world-list {
    flex-direction: column;
    gap: 6;
    overflow: scroll;
    max-height: 280;
  }

  .divider {
    height: 1;
    background-color: rgba(255, 255, 255, 0.1);
  }

  .xr-btn {
    padding-vertical: 10;
    border-radius: 16;
    justify-content: center;
    align-items: center;
    background-color: rgba(255, 255, 255, 0.07);
    margin-top: 2;
  }
</style>

<div class="panel">
  <div class="panel-title">⬡  W O R L D S</div>

  <div id="status-bar" class="status-bar"></div>

  <div class="btn-row">
    <div id="scout-btn" class="btn-scout"></div>
    <div id="gen-btn" class="btn-gen"></div>
  </div>

  <div class="divider"></div>
  <div class="section-label">GENERATED WORLDS</div>
  <div id="world-list" class="world-list"></div>

  <div class="divider"></div>
  <div id="xr-button" class="xr-btn"></div>
</div>
